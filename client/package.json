        "vue": "^3.3.11",
        "vue-router": "^5.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.0.10",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/tsconfig": "^0.9.0",
